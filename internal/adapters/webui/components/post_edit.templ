package components

import (
	"strings"

	"github.com/jtprogru/jtpost/internal/core"
)

// PostEditProps — данные edit page для существующего поста.
type PostEditProps struct {
	Post      *core.Post
	UserEmail string
	Saved     bool   // ?saved=1 — показать success-flash
	Reverted  bool   // ?reverted=1 — показать revert-success-flash
	Error     string // inline error (validation / save fail)
}

templ PostEdit(p PostEditProps) {
	@Layout(LayoutProps{Title: p.Post.Title, ActiveNav: "dashboard", UserEmail: p.UserEmail}) {
		<div class="post-edit">
			<div class="post-edit__header">
				<a href="/ui/" class="post-edit__back">← All posts</a>
				<h1>{ p.Post.Title }</h1>
				<div class="post-edit__meta">
					<span class={ "status status--" + string(p.Post.Status) }>
						{ string(p.Post.Status) }
					</span>
					<span class="post-edit__id">id: { p.Post.ID.String() }</span>
					<a href={ templ.URL("/ui/posts/" + p.Post.ID.String() + "/history") } class="post-edit__back">📜 History</a>
				</div>
			</div>

			if p.Saved {
				<div class="form-success">✓ Сохранено</div>
			}
			if p.Reverted {
				<div class="form-success">✓ Пост возвращён к выбранной ревизии</div>
			}
			if p.Error != "" {
				<div class="form-error">{ p.Error }</div>
			}

			<form
				method="post"
				action={ templ.URL("/ui/posts/" + p.Post.ID.String()) }
				class="post-edit__form"
			>
				<label>
					Title
					<input type="text" name="title" value={ p.Post.Title } required/>
				</label>
				<label>
					Status
					<select name="status">
						for _, s := range []string{"idea", "draft", "ready", "scheduled", "published", "failed"} {
							<option value={ s } selected?={ string(p.Post.Status) == s }>{ s }</option>
						}
					</select>
				</label>
				<label>
					Tags (comma-separated)
					<input type="text" name="tags" value={ strings.Join(p.Post.Tags, ", ") }/>
				</label>
				<div class="post-edit__split">
					<label class="post-edit__editor">
						Content (Markdown)
						<div class="post-edit__editor-actions">
							<button type="button" class="btn btn--ghost" onclick="document.getElementById('md-image-input').click()">
								📎 Upload image
							</button>
							<span class="post-edit__upload-hint">или перетащи файл в редактор</span>
							<input type="file" id="md-image-input" accept="image/*" style="display:none" onchange="jtpostUploadFiles(this.files)"/>
						</div>
						<textarea
							id="md-textarea"
							name="content"
							rows="22"
							ondragover="event.preventDefault(); this.classList.add('drop-active')"
							ondragleave="this.classList.remove('drop-active')"
							ondrop="event.preventDefault(); this.classList.remove('drop-active'); jtpostUploadFiles(event.dataTransfer.files)"
							hx-post="/ui/preview"
							hx-trigger="input changed delay:400ms"
							hx-target="#md-preview"
							hx-swap="innerHTML"
						>{ p.Post.Content }</textarea>
					</label>
					<div class="post-edit__preview">
						<span class="post-edit__preview-label">Preview</span>
						<div id="md-preview" class="md-preview">
							@RenderedMarkdown(p.Post.Content)
						</div>
					</div>
				</div>
				<div class="post-edit__actions">
					<button type="submit" class="btn">Save</button>
					<a href="/ui/" class="post-edit__back">Cancel</a>
				</div>
			</form>
			<form
				method="post"
				action={ templ.URL("/ui/posts/" + p.Post.ID.String() + "/delete") }
				onsubmit="return confirm('Удалить пост безвозвратно?');"
				class="post-edit__delete-form"
			>
				<button type="submit" class="btn btn--danger">Удалить пост</button>
			</form>
		</div>
	}
}

// RenderedMarkdown оборачивает HTML-партиал, отрендеренный из MD на сервере.
// `html` приходит как уже-санитизированный HTML (см. webui/markdown.go),
// поэтому используем templ.Raw без HTML-escape.
templ RenderedMarkdown(rawMD string) {
	@templ.Raw(MarkdownToHTML(rawMD))
}
